# AegisAIS — Environment Variable Reference
# Copy to .env and fill in secrets.

# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-random-32+-char-string

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./aegisais.db
# Production PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://user:pass@db:5432/aegisais

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Live AIS Feed (Issue #3 — GAP-02) ─────────────────────────────────────
# Free API key: https://aisstream.io
AISSSTREAM_API_KEY=
# Bounding box filter: lat_min,lon_min,lat_max,lon_max
# Default Baltic Sea region: 54.0,9.0,66.0,30.0
AISSTREAM_BBOX=

# ── Malware Scanning (Issue #2) ────────────────────────────────────────────
# Set true to enable ClamAV scanning on every upload.
# Requires: docker compose -f docker-compose.yml -f infra/docker-compose.clamav.yml up
SCAN_UPLOADS_FOR_MALWARE=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
# Unix socket alternative (overrides HOST/PORT if set):
# CLAMAV_SOCKET=/var/run/clamav/clamd.ctl

# ── ITDAE ──────────────────────────────────────────────────────────────────
ITDAE_AIS_API_KEY=
ITDAE_BALTIC_BBOX=

# ── Auth ───────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Audit ──────────────────────────────────────────────────────────────────
ENABLE_AUDIT_LOGGING=true

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5173,http://localhost:3000

# ── Optional: SMTP ─────────────────────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=

# ── Optional: Sentry ───────────────────────────────────────────────────────
# SENTRY_DSN=

# ── S-AIS ──────────────────────────────────────────────────────────────────
SAIS_PROVIDER=none
# SAIS_API_KEY=
# MARINETRAFFIC_API_KEY=
