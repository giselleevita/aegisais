{
  "name": "aegisais-monorepo",
  "version": "1.0.0",
  "packageManager": "npm@10.8.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "overrides": {
    "picomatch": ">=4.0.4",
    "minimatch": ">=9.0.7",
    "brace-expansion": ">=2.0.3",
    "ajv": ">=6.14.0",
    "rollup": ">=4.59.0",
    "vite": "^8.0.16"
  }
}
