# Frontend Environment Configuration
# Copy this file to .env.local and update values for your environment

# API Backend URL
# For local development: http://localhost:8001
# For staging: https://api-staging.aegisais.example.com
# For production: https://api.aegisais.example.com
VITE_API_BASE_URL=http://localhost:8001

# UI Mode Selection
# Set to 'true' to use the legacy tabbed UI instead of the modern globe/map view
# Default: false (uses new globe workbench UI)
VITE_USE_LEGACY_UI=false

# WebSocket Configuration (optional)
# If different from API base URL, specify the WebSocket endpoint
# Default: derived from VITE_API_BASE_URL (/ws path)
# VITE_WEBSOCKET_URL=ws://localhost:8001/ws

# Feature Flags
# Uncomment to enable experimental features
# VITE_ENABLE_GLOBE_VIEWER=true
# VITE_ENABLE_IOT_TELEMETRY=true
# VITE_ENABLE_ASSET_TRACKING=true
# VITE_ENABLE_MFA_UI=true

# Cesium Ion Token (optional, for advanced Cesium features)
# Get token from: https://ion.cesium.com
# VITE_CESIUM_ION_TOKEN=
